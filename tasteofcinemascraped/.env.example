# OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Primary model — full content translation (long-form, high quality)
# Recommended: google/gemini-2.5-pro, openai/gpt-4o
OPENROUTER_MODEL=google/gemini-2.5-pro

# Fast model — metadata batch (title, bio, tags, extra tags, category classification)
# Recommended: google/gemini-2.0-flash-lite, openai/gpt-4o-mini
# Leave empty or omit to use OPENROUTER_MODEL for everything (slower, more expensive)
OPENROUTER_FAST_MODEL=google/gemini-2.0-flash-lite

# WordPress plugin endpoint (tasteofcinemascraped-wp)
WORDPRESS_URL=http://your-local-site.test/
WORDPRESS_ENDPOINT_PATH=wp-json/tasteofcinemascraped/v1/import
WORDPRESS_SECRET=your-secret-key-here

# Dual Site Publishing (tasteofcinemascraped-wp → remote)
REMOTE_WP_URL=https://your-live-site.com
REMOTE_WP_USER=your_wp_username
REMOTE_WP_APP_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"
